# Copy to deploy/portfolio.env on the VPS and replace every change-me value.

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
ORIGIN=https://portfolio.404connernotfound.dev
HOST_APP_PORT=3000
HOST_PLAYGROUND_WS_PORT=24680

# SvelteKit adapter-node reverse proxy settings. Keep these only when Nginx is the trusted proxy.
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host
PORT_HEADER=x-forwarded-port
ADDRESS_HEADER=X-Real-IP
XFF_DEPTH=

BODY_SIZE_LIMIT=8M
SHUTDOWN_TIMEOUT=30
IDLE_TIMEOUT=60
HEALTHZ_VERBOSE=false

POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://portfolio:change-me@postgres:5432/portfolio
PG_SSL=false
PG_POOL_MAX=10

DB_PATH=/data/portfolio.sqlite
DB_AUTO_SEED=false

REDIS_URL=redis://redis:6379
REDIS_PREFIX=portfolio:

ADMIN_SESSION_SECRET=change-me-generate-at-least-32-random-bytes
ADMIN_SESSION_VERSION=1
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_TOKEN=
LEAD_NOTIFY_TIMEOUT_MS=2500

PLAYGROUND_ENABLED=false
PLAYGROUND_REQUIRE_ADMIN=true
PLAYGROUND_ENFORCE_SAME_ORIGIN=true
PLAYGROUND_RUNTIME_MODE=docker
PLAYGROUND_DOCKER_BINARY=docker
PLAYGROUND_WS_HOST=0.0.0.0
PLAYGROUND_WS_PORT=24680
PLAYGROUND_WS_PATH=/playground/ws
PLAYGROUND_WS_PUBLIC_URL=wss://portfolio.404connernotfound.dev/playground/ws
PLAYGROUND_CREATE_RATE_LIMIT_PER_MINUTE=3
PLAYGROUND_COMMAND_TIMEOUT_MS=20000
PLAYGROUND_MAX_OUTPUT_BYTES=64000
PLAYGROUND_MAX_COMMANDS_PER_SESSION=40
PLAYGROUND_COMMAND_RATE_WINDOW_MS=10000
PLAYGROUND_MAX_COMMANDS_PER_WINDOW=8
