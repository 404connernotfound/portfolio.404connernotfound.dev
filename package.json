{
	"name": "portfolio-website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "npm@11.13.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node --env-file-if-exists=.env build/index.js",
		"preview": "vite preview",
		"deploy:check": "npm run check && npm run lint && npm run build",
		"deploy:vps": "bash scripts/deploy-vps.sh",
		"deploy:cleanup": "bash scripts/cleanup-vps.sh",
		"deploy:clean-slate": "bash scripts/clean-slate-vps.sh",
		"deploy:smoke:no-dns": "bash scripts/smoke-vps-no-dns.sh",
		"deploy:auto-update": "bash scripts/auto-update-vps.sh",
		"deploy:auto-update:install": "bash scripts/install-auto-update.sh",
		"nginx:setup": "bash scripts/setup-cloudflare-nginx.sh",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"db:seed": "tsx scripts/seed-db.ts",
		"db:migrate:postgres": "tsx scripts/migrate-sqlite-to-postgres.ts",
		"test": "tsx tests/content.test.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.2.1",
		"@types/pg": "^8.15.6",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-svelte": "^2.46.1",
		"postcss": "^8.4.38",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"sass": "^1.97.3",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"svelte-eslint-parser": "^0.43.0",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"better-sqlite3": "^12.6.2",
		"gsap": "^3.14.2",
		"pg": "^8.16.3",
		"redis": "^5.8.2",
		"svelte-motion": "^0.12.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		],
		"ignoredBuiltDependencies": [
			"@parcel/watcher",
			"svelte-preprocess"
		]
	}
}
